# ============================================
# 环境与项目
# ============================================
ENVIRONMENT=local
PROJECT_NAME="NOS Agent Carrier"
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"

# ============================================
# 认证与安全
# ============================================
SECRET_KEY=changethis
ACCESS_TOKEN_EXPIRE_MINUTES=11520
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ============================================
# PostgreSQL 数据库
# ============================================
# Docker 模式下 POSTGRES_SERVER 会被 docker-compose.yml 自动覆盖为 db
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# ============================================
# 可选：监控
# ============================================
SENTRY_DSN=

# ============================================
# 文件上传
# ============================================
UPLOAD_STORAGE_DRIVER=local
UPLOAD_PUBLIC_DIR=storage/uploads/public
UPLOAD_PRIVATE_DIR=storage/uploads/private
UPLOAD_PUBLIC_URL_PREFIX=/uploads/public
UPLOAD_MAX_IMAGE_SIZE_MB=5
UPLOAD_ALLOWED_IMAGE_EXTENSIONS=png,jpg,jpeg,webp,ico
